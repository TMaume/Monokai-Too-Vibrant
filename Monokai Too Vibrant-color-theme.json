{
  "name": "Monokai Super Vibrant",
  "type": "dark",
  "tokenColors": [
    {
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Comment",
      "scope": ["comment", "string.comment"],
      "settings": {
        "foreground": "#6B7382",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": "string",
      "settings": {
        "foreground": "#FFFF00"
      }
    },
    {
      "name": "Punctuation Template Expression",
      "scope": "punctuation.definition.template-expression.begin, punctuation.definition.template-expression.end, punctuation.section.embedded",
      "settings": {
        "foreground": "#FF0033"
      }
    },
    {
      "name": "TemplateString",
      "scope": "meta.string.template",
      "settings": {
        "foreground": "#FF9900"
      }
    },
    {
      "name": "Meta",
      "scope": "meta",
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "Embeded String Begin and End",
      "scope": ["string.embedded.begin", "string.embedded.end"],
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "Embeded String",
      "scope": "string.embedded",
      "settings": {
        "foreground": "#00FF00"
      }
    },
    {
      "name": "Built-in constant",
      "scope": "constant.language",
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "User-defined constant",
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "Language Variable",
      "scope": "variable.language",
      "settings": {
        "foreground": "#FF0033",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable.readwrite", "variable.readwrite.other.block"],
      "settings": {
        "foreground": "#0077FF"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.operator.logical",
        "keyword.operator.constructor"
      ],
      "settings": {
        "foreground": "#FF0033"
      }
    },
    {
      "name": "Keyword Operator",
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#FF0033"
      }
    },
    {
      "name": "Storage",
      "scope": "storage",
      "settings": {
        "foreground": "#FF0033",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage type",
      "scope": "storage.type",
      "settings": {
        "foreground": "#00FFFF"
      }
    },
    {
      "name": "Class name",
      "scope": [
        "entity.name.class",
        "entity.name.module",
        "entity.name.type",
        "storage.identifier",
        "support.class"
      ],
      "settings": {
        "foreground": "#0077FF"
      }
    },
    {
      "name": "Variable Object",
      "scope": ["meta.block.switch.c", "variable.other.object"],
      "settings": {
        "foreground": "#0077FF"
      }
    },
    {
      "name": "Other variable",
      "scope": ["variable.other.property", "variable.other.block"],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Inherited class",
      "scope": "entity.other.inherited-class",
      "settings": {
        "foreground": "#33FF00"
      }
    },
    {
      "name": "Function name",
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#33FF00"
      }
    },
    {
      "name": "Library function",
      "scope": "support.function",
      "settings": {
        "foreground": "#00FFFF"
      }
    },
    {
      "name": "Function argument",
      "scope": "variable.parameter",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#FF6600"
      }
    },
    {
      "name": "Function call",
      "scope": "entity.name.function-call",
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Builtin Functions",
      "scope": ["function.support.builtin", "function.support.core"],
      "settings": {
        "foreground": "#33FF00"
      }
    },
    {
      "name": "Tag name",
      "scope": [
        "entity.name.tag",
        "entity.name.tag.class.js",
        "entity.name.tag.class.jsx"
      ],
      "settings": {
        "foreground": "#FF0033"
      }
    },
    {
      "name": "Tag Class and ID",
      "scope": ["entity.name.tag.class", "entity.name.tag.id"],
      "settings": {
        "foreground": "#00FFFF"
      }
    },
    {
      "name": "Tag attribute",
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#33FF00"
      }
    },
    {
      "name": "Library constant",
      "scope": "support.constant",
      "settings": {
        "foreground": "#00FFFF"
      }
    },
    {
      "name": "Library class/type",
      "scope": ["support.type", "support.variable"],
      "settings": {
        "foreground": "#00FFFF"
      }
    },
    {
      "name": "Json Property",
      "scope": "support.dictionary.json",
      "settings": {
        "foreground": "#00FFFF"
      }
    },
    {
      "name": "StyleSheet Property name",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss",
        "support.type.property-name.less",
        "support.type.property-name.sass"
      ],
      "settings": {
        "foreground": "#00E5FF"
      }
    },
    {
      "name": "StyleSheet Property value",
      "scope": [
        "support.constant.css",
        "support.constant.scss",
        "support.constant.less",
        "support.constant.sass"
      ],
      "settings": {
        "foreground": "#00FF00"
      }
    },
    {
      "name": "StyleSheet Variable",
      "scope": [
        "variable.css",
        "variable.scss",
        "variable.less",
        "variable.sass"
      ],
      "settings": {
        "foreground": "#00FFFF"
      }
    },
    {
      "name": "StyleSheet Variable String",
      "scope": [
        "variable.css.string",
        "variable.scss.string",
        "variable.less.string",
        "variable.sass.string"
      ],
      "settings": {
        "foreground": "#FFCC00"
      }
    },
    {
      "name": "StyleSheet Unit",
      "scope": ["unit.css", "unit.scss", "unit.less", "unit.sass"],
      "settings": {
        "foreground": "#CC00FF"
      }
    },
    {
      "name": "StyleSheet Number",
      "scope": [
        "constant.numeric.css",
        "constant.numeric.scss",
        "constant.numeric.less",
        "constant.numeric.sass"
      ],
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "StyleSheet Function",
      "scope": [
        "function.css",
        "function.scss",
        "function.less",
        "function.sass"
      ],
      "settings": {
        "foreground": "#00FFFF"
      }
    },
    {
      "name": "Library variable",
      "scope": "support.other.variable",
      "settings": {
        "fontStyle": ""
      }
    },
    {
      "name": "Invalid",
      "scope": "invalid",
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Invalid deprecated",
      "scope": "invalid.deprecated",
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "JSON String",
      "scope": "structure.dictionary.property-name.json",
      "settings": {
        "foreground": "#00E5FF"
      }
    },
    {
      "name": "Link",
      "scope": "string.detected-link",
      "settings": {
        "foreground": "#0077FF"
      }
    },
    {
      "name": "diff.header",
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#75715E"
      }
    },
    {
      "name": "diff.deleted",
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "diff.inserted",
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#FFCC00"
      }
    },
    {
      "name": "diff.changed",
      "scope": "markup.changed",
      "settings": {
        "foreground": "#FFCC00"
      }
    },
    {
      "scope": "constant.numeric.line-number.find-in-files - match",
      "settings": {
        "foreground": "#00FFFF"
      }
    },
    {
      "scope": "entity.name.filename.find-in-files",
      "settings": {
        "foreground": "#FFCC00"
      }
    },
    {
      "name": "Markup: Emphasis",
      "scope": "markup.italic, markup.italic.markdown",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup: Emphasis Punctuation",
      "scope": "punctuation.definition.italic.markdown",
      "settings": {
        "fontStyle": "",
        "foreground": "#888888"
      }
    },
    {
      "name": "Markdown: Link",
      "scope": "markup.underline.link.markdown",
      "settings": {
        "foreground": "#0077FF"
      }
    },
    {
      "name": "Markdown: Bold",
      "scope": "markup.bold.markdown",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown: Bold Punctuation",
      "scope": "punctuation.definition.bold.markdown",
      "settings": {
        "fontStyle": "",
        "foreground": "#AAAAAA"
      }
    },
    {
      "name": "Markdown: Heading",
      "scope": "markup.heading.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#FF0033"
      }
    },
    {
      "name": "Markdown: Heading",
      "scope": "punctuation.definition.heading.markdown",
      "settings": {
        "fontStyle": "",
        "foreground": "#AAAAAA"
      }
    },
    {
      "name": "Markdown: Quote",
      "scope": "markup.quote.markdown",
      "settings": {
        "foreground": "#33FF00"
      }
    },
    {
      "name": "Markdown: Separator",
      "scope": "meta.separator.markdown",
      "settings": {
        "foreground": "#FF00FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown: Raw",
      "scope": "markup.raw.inline.markdown, markup.raw.block.markdown",
      "settings": {
        "foreground": "#00FFFF"
      }
    },
    {
      "name": "Markdown: List Punctuation",
      "scope": "punctuation.definition.list_item.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "JSDoc: Variable",
      "scope": "variable.other.jsdoc",
      "settings": {
        "foreground": "#A0A0A0"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "newOperator": "#FF0033",
    "stringLiteral": "#FFFF00",
    "customLiteral": "#33FF00",
    "numberLiteral": "#FF00FF",
    "variable": "#CCCCCC",
    "variable.readonly": "#FFFFFF",
    "variable.defaultLibrary": "#FFFFFF"
  },
  "colors": {
    "activityBar.background": "#000000",
    "activityBar.foreground": "#FFFFFF",
    "activityBarBadge.background": "#0077FF",
    "activityBarBadge.foreground": "#FFFFFF",
    "button.background": "#0077FF",
    "dropdown.background": "#0A0A0A",
    "diffEditor.insertedTextBackground": "#00FF0033",
    "dropdown.border": "#222222",
    "editor.background": "#000000",
    "editor.foreground": "#FFFFFF",
    "editorError.foreground": "#FF0033",
    "editorRuler.foreground": "#333333",
    "editor.lineHighlightBackground": "#111111",
    "editor.selectionBackground": "#0044AA",
    "editorCursor.foreground": "#FFFFFF",
    "editor.findMatchBackground": "#0055FF80",
    "editor.findMatchHighlightBackground": "#0033AA80",
    "editorGroup.border": "#222222",
    "editorGroupHeader.tabsBackground": "#050505",
    "editorIndentGuide.background": "#222222",
    "editorLineNumber.foreground": "#555555",
    "editorWhitespace.foreground": "#222222",
    "editorHoverWidget.background": "#0A0A0A",
    "editorHoverWidget.border": "#333333",
    "editorSuggestWidget.background": "#0A0A0A",
    "editorSuggestWidget.border": "#333333",
    "editorSuggestWidget.selectedBackground": "#222222",
    "editorWidget.background": "#0A0A0A",
    "input.background": "#0A0A0A",
    "list.activeSelectionBackground": "#222222",
    "list.activeSelectionForeground": "#FFFFFF",
    "list.focusBackground": "#333333",
    "list.hoverBackground": "#111111",
    "list.highlightForeground": "#FFFFFF",
    "list.inactiveSelectionBackground": "#1A1A1A",
    "list.inactiveSelectionForeground": "#CCCCCC",
    "scrollbarSlider.background": "#33333380",
    "scrollbarSlider.activeBackground": "#77777780",
    "scrollbarSlider.hoverBackground": "#55555580",
    "sideBar.background": "#050505",
    "sideBarSectionHeader.background": "#0A0A0A",
    "statusBar.background": "#000000",
    "statusBar.foreground": "#FFFFFF",
    "statusBarItem.hoverBackground": "#222222",
    "statusBar.noFolderBackground": "#050505",
    "statusBar.debuggingBackground": "#FF0033",
    "tab.activeBackground": "#111111",
    "tab.border": "#000000",
    "tab.activeBorderTop": "#0077FF",
    "tab.inactiveBackground": "#050505",
    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#FFFFFF",
    "titleBar.inactiveBackground": "#050505",
    "titleBar.inactiveForeground": "#888888",
    "editorInlayHint.foreground": "#AAAAAA",
    "editorInlayHint.background": "#111111",
    "editorHoverWidget.highlightForeground": "#FFFFFF"
  }
}