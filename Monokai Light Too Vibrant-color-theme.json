{
  "name": "Monokai Light Too Vibrant",
  "type": "light",
  "tokenColors": [
    {
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Comment",
      "scope": ["comment", "string.comment"],
      "settings": {
        "foreground": "#888888",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": "string",
      "settings": {
        "foreground": "#FF7700"
      }
    },
    {
      "name": "Punctuation Template Expression",
      "scope": "punctuation.definition.template-expression.begin, punctuation.definition.template-expression.end, punctuation.section.embedded",
      "settings": {
        "foreground": "#FF0000"
      }
    },
    {
      "name": "TemplateString",
      "scope": "meta.string.template",
      "settings": {
        "foreground": "#FF5500"
      }
    },
    {
      "name": "Meta",
      "scope": "meta",
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "Embeded String Begin and End",
      "scope": ["string.embedded.begin", "string.embedded.end"],
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "Embeded String",
      "scope": "string.embedded",
      "settings": {
        "foreground": "#00BB00"
      }
    },
    {
      "name": "Built-in constant",
      "scope": "constant.language",
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "User-defined constant",
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "Language Variable",
      "scope": "variable.language",
      "settings": {
        "foreground": "#FF0000",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable.readwrite", "variable.readwrite.other.block"],
      "settings": {
        "foreground": "#0000FF"
      }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.operator.logical", "keyword.operator.constructor"],
      "settings": {
        "foreground": "#FF0000"
      }
    },
    {
      "name": "Keyword Operator",
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#FF0000"
      }
    },
    {
      "name": "Storage",
      "scope": "storage",
      "settings": {
        "foreground": "#FF0000",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage type",
      "scope": "storage.type",
      "settings": {
        "foreground": "#00AAAA"
      }
    },
    {
      "name": "Class name",
      "scope": ["entity.name.class", "entity.name.module", "entity.name.type", "storage.identifier", "support.class"],
      "settings": {
        "foreground": "#0000FF"
      }
    },
    {
      "name": "Variable Object",
      "scope": ["meta.block.switch.c", "variable.other.object"],
      "settings": {
        "foreground": "#0000FF"
      }
    },
    {
      "name": "Other variable",
      "scope": ["variable.other.property", "variable.other.block"],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Inherited class",
      "scope": "entity.other.inherited-class",
      "settings": {
        "foreground": "#00BB00"
      }
    },
    {
      "name": "Function name",
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#00BB00"
      }
    },
    {
      "name": "Library function",
      "scope": "support.function",
      "settings": {
        "foreground": "#00AAAA"
      }
    },
    {
      "name": "Function argument",
      "scope": "variable.parameter",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#FF5500"
      }
    },
    {
      "name": "Function call",
      "scope": "entity.name.function-call",
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Builtin Functions",
      "scope": ["function.support.builtin", "function.support.core"],
      "settings": {
        "foreground": "#00BB00"
      }
    },
    {
      "name": "Tag name",
      "scope": ["entity.name.tag", "entity.name.tag.class.js", "entity.name.tag.class.jsx"],
      "settings": {
        "foreground": "#FF0000"
      }
    },
    {
      "name": "Tag Class and ID",
      "scope": ["entity.name.tag.class", "entity.name.tag.id"],
      "settings": {
        "foreground": "#00AAAA"
      }
    },
    {
      "name": "Tag attribute",
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#00BB00"
      }
    },
    {
      "name": "Library constant",
      "scope": "support.constant",
      "settings": {
        "foreground": "#00AAAA"
      }
    },
    {
      "name": "Library class/type",
      "scope": ["support.type", "support.variable"],
      "settings": {
        "foreground": "#00AAAA"
      }
    },
    {
      "name": "Json Property",
      "scope": "support.dictionary.json",
      "settings": {
        "foreground": "#00AAAA"
      }
    },
    {
      "name": "StyleSheet Property name",
      "scope": ["support.type.property-name.css", "support.type.property-name.scss", "support.type.property-name.less", "support.type.property-name.sass"],
      "settings": {
        "foreground": "#0099DD"
      }
    },
    {
      "name": "StyleSheet Property value",
      "scope": ["support.constant.css", "support.constant.scss", "support.constant.less", "support.constant.sass"],
      "settings": {
        "foreground": "#00BB00"
      }
    },
    {
      "name": "StyleSheet Variable",
      "scope": ["variable.css", "variable.scss", "variable.less", "variable.sass"],
      "settings": {
        "foreground": "#00AAAA"
      }
    },
    {
      "name": "StyleSheet Variable String",
      "scope": ["variable.css.string", "variable.scss.string", "variable.less.string", "variable.sass.string"],
      "settings": {
        "foreground": "#DD9900"
      }
    },
    {
      "name": "StyleSheet Unit",
      "scope": ["unit.css", "unit.scss", "unit.less", "unit.sass"],
      "settings": {
        "foreground": "#AA00FF"
      }
    },
    {
      "name": "StyleSheet Number",
      "scope": ["constant.numeric.css", "constant.numeric.scss", "constant.numeric.less", "constant.numeric.sass"],
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "StyleSheet Function",
      "scope": ["function.css", "function.scss", "function.less", "function.sass"],
      "settings": {
        "foreground": "#00AAAA"
      }
    },
    {
      "name": "Library variable",
      "scope": "support.other.variable",
      "settings": {
        "fontStyle": ""
      }
    },
    {
      "name": "Invalid",
      "scope": "invalid",
      "settings": {
        "foreground": "#FF0000"
      }
    },
    {
      "name": "JSON String",
      "scope": "structure.dictionary.property-name.json",
      "settings": {
        "foreground": "#0099DD"
      }
    },
    {
      "name": "Link",
      "scope": "string.detected-link",
      "settings": {
        "foreground": "#0000FF"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "newOperator": "#FF0000",
    "stringLiteral": "#FF7700",
    "customLiteral": "#00BB00",
    "numberLiteral": "#FF00FF",
    "variable": "#444444",
    "variable.readonly": "#000000",
    "variable.defaultLibrary": "#000000"
  },
  "colors": {
    "activityBar.background": "#F5F5F5",
    "activityBar.foreground": "#000000",
    "activityBarBadge.background": "#0000FF",
    "activityBarBadge.foreground": "#FFFFFF",
    "button.background": "#0000FF",
    "dropdown.background": "#FFFFFF",
    "diffEditor.insertedTextBackground": "#00BB0033",
    "dropdown.border": "#CCCCCC",
    "editor.background": "#FFFFFF",
    "editor.foreground": "#000000",
    "editorError.foreground": "#FF0000",
    "editorRuler.foreground": "#E0E0E0",
    "editor.lineHighlightBackground": "#F0F0F0",
    "editor.selectionBackground": "#BBDDFF",
    "editorCursor.foreground": "#000000",
    "editor.findMatchBackground": "#0088FF80",
    "editor.findMatchHighlightBackground": "#00AAFF40",
    "editorGroup.border": "#DDDDDD",
    "editorGroupHeader.tabsBackground": "#F0F0F0",
    "editorIndentGuide.background": "#E0E0E0",
    "editorLineNumber.foreground": "#999999",
    "editorWhitespace.foreground": "#E0E0E0",
    "editorHoverWidget.background": "#FFFFFF",
    "editorHoverWidget.border": "#CCCCCC",
    "editorSuggestWidget.background": "#FFFFFF",
    "editorSuggestWidget.border": "#CCCCCC",
    "editorSuggestWidget.selectedBackground": "#E8E8E8",
    "editorWidget.background": "#FFFFFF",
    "input.background": "#FFFFFF",
    "list.activeSelectionBackground": "#DDEEFF",
    "list.activeSelectionForeground": "#000000",
    "list.focusBackground": "#E8E8E8",
    "list.hoverBackground": "#F5F5F5",
    "list.highlightForeground": "#0000FF",
    "list.inactiveSelectionBackground": "#EEEEEE",
    "list.inactiveSelectionForeground": "#333333",
    "scrollbarSlider.background": "#CCCCCC80",
    "scrollbarSlider.activeBackground": "#99999980",
    "scrollbarSlider.hoverBackground": "#AAAAAA80",
    "sideBar.background": "#FAFAFA",
    "sideBarSectionHeader.background": "#F0F0F0",
    "statusBar.background": "#F5F5F5",
    "statusBar.foreground": "#000000",
    "statusBarItem.hoverBackground": "#E8E8E8",
    "statusBar.noFolderBackground": "#F5F5F5",
    "statusBar.debuggingBackground": "#FF0000",
    "tab.activeBackground": "#FFFFFF",
    "tab.border": "#DDDDDD",
    "tab.activeBorderTop": "#0000FF",
    "tab.inactiveBackground": "#F0F0F0",
    "titleBar.activeBackground": "#F5F5F5",
    "titleBar.activeForeground": "#000000",
    "titleBar.inactiveBackground": "#FAFAFA",
    "titleBar.inactiveForeground": "#777777",
    "editorInlayHint.foreground": "#666666",
    "editorInlayHint.background": "#F0F0F0",
    "editorHoverWidget.highlightForeground": "#000000"
  }
}